# Agent System Configuration

# Anthropic Claude API Key (required for AI features)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Custom Claude model (default: claude-sonnet-4-5-20250514)
# ANTHROPIC_MODEL=claude-opus-4-6-20250514

# Optional: Default temperature (0-1)
# AGENT_TEMPERATURE=0.5

# Optional: Max tokens for responses
# AGENT_MAX_TOKENS=4000

# Optional: Enable debug logging
# DEBUG=agents:*
